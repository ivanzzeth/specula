# (Keep this comment; do NOT ignore charts/*.tgz once vendored.)
# /deploy/helm/specula/charts/

# OCI conformance suite run artifacts (scripts/oci-conformance.sh writes these
# under $WORK; this guards against the binary being run from the repo root).
/results/
